<html>
<head>
<title>World Menu POS</title>
<HTA:APPLICATION
  ID="WorldMenuInstaller"
  APPLICATIONNAME="World Menu POS"
  BORDER="thin"
  BORDERSTYLE="normal"
  CAPTION="yes"
  MAXIMIZEBUTTON="yes"
  MINIMIZEBUTTON="yes"
  SCROLL="no"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  SYSMENU="yes"
  WINDOWSTATE="normal"
/>
<style>
* { margin: 0; padding: 0; }
body { font-family: Segoe UI, Arial, sans-serif; background: #0f172a; color: #e2e8f0; overflow: hidden; text-align: center; }
.wrap { padding: 40px 50px; }
.dots { margin-bottom: 30px; }
.dot { display: inline-block; width: 120px; height: 6px; background: #1e293b; margin: 0 3px; }
.step { padding: 10px 0; }
h1 { font-size: 42px; color: #fff; margin-bottom: 4px; }
h2 { font-size: 28px; color: #fff; margin-bottom: 10px; }
.big-emoji { font-size: 72px; margin-bottom: 16px; }
.tagline { font-size: 18px; color: #f59e0b; margin-bottom: 6px; font-weight: bold; }
.desc { font-size: 16px; color: #94a3b8; line-height: 1.6; margin-bottom: 28px; }
.small { font-size: 13px; color: #64748b; margin-top: 16px; }
.ver { font-size: 11px; color: #334155; margin-top: 4px; }
.btn { padding: 18px 48px; border: none; font-size: 18px; font-weight: bold; cursor: pointer; margin: 6px; color: #fff; }
.btn-go { background: #f59e0b; color: #0f172a; }
.btn-blue { background: #3b82f6; }
.btn-green { background: #22c55e; }
.btn-gray { background: #334155; color: #94a3b8; }
.btn-big { padding: 22px 60px; font-size: 22px; }
.ftable { margin: 0 auto 28px auto; }
.ftable td { font-size: 15px; color: #cbd5e1; padding: 10px 18px; background: #1e293b; text-align: left; }
.ftable .ficon { font-size: 20px; padding-right: 6px; }
.checks { width: 460px; margin: 0 auto 24px auto; text-align: left; }
.chk { padding: 14px 18px; margin-bottom: 8px; background: #1e293b; font-size: 15px; color: #cbd5e1; }
.chk-icon { display: inline-block; width: 32px; text-align: center; font-size: 13px; font-weight: bold; margin-right: 12px; padding: 2px 0; }
.log { width: 500px; height: 90px; background: #080c14; border: 1px solid #1e293b; padding: 10px; font-family: Consolas, monospace; font-size: 12px; color: #64748b; overflow-y: auto; text-align: left; margin: 0 auto 20px auto; }
.path-box { background: #1e293b; padding: 18px 28px; font-family: Consolas; font-size: 16px; color: #60a5fa; display: inline-block; margin-bottom: 24px; }
.err-box { display: none; color: #fca5a5; font-size: 14px; background: #1e293b; padding: 12px 18px; margin: 12px auto; width: 460px; }
</style>
<script>
var shell = new ActiveXObject("WScript.Shell");
var fso = new ActiveXObject("Scripting.FileSystemObject");
var nodeFound = false;
var appVersion = "1.0.0";

// Detect where THIS file is running from
function getSourceDir() {
  var htaPath = document.location.pathname.replace(/\//g, '\\');
  if (htaPath.charAt(0) == '\\') htaPath = htaPath.substring(1);
  return htaPath.substring(0, htaPath.lastIndexOf('\\'));
}

// Install location
var installDir = 'C:\\World Menu POS';

// Find where the source files are (on USB or wherever HTA is)
function getSourceFiles() {
  var src = getSourceDir();
  if (fso.FileExists(src + '\\package.json')) return src;
  if (fso.FolderExists(src + '\\world-menu-pos') && fso.FileExists(src + '\\world-menu-pos\\package.json')) return src + '\\world-menu-pos';
  return src;
}

function getInstallDir() {
  return installDir;
}

function getVersion() {
  try {
    var dir = getInstallDir();
    var vPath = dir + '\\version.json';
    if (fso.FileExists(vPath)) {
      var f = fso.OpenTextFile(vPath, 1);
      var txt = f.ReadAll(); f.Close();
      var m = txt.match(/"version"\s*:\s*"([^"]+)"/);
      if (m) return m[1];
    }
  } catch(e) {}
  return '1.0.0';
}

function resizeWindow() {
  window.resizeTo(820, 720);
  var sl = (screen.width - 820) / 2;
  var st = (screen.height - 720) / 2;
  window.moveTo(sl, st);
}

function showStep(n) {
  for (var i = 0; i < 4; i++) {
    var s = document.getElementById('s' + i);
    if (s) s.style.display = (i == n) ? '' : 'none';
    var d = document.getElementById('d' + i);
    if (d) d.style.background = (i < n ? '#22c55e' : (i == n ? '#f59e0b' : '#1e293b'));
  }
}

function log(msg) {
  var el = document.getElementById('logBox');
  if (el) { el.innerHTML += msg + '<br>'; el.scrollTop = el.scrollHeight; }
}

function setIcon(id, status) {
  var el = document.getElementById(id);
  if (!el) return;
  if (status == 'ok') { el.style.background = '#22c55e'; el.style.color = '#fff'; el.innerHTML = 'YES'; }
  else if (status == 'fail') { el.style.background = '#ef4444'; el.style.color = '#fff'; el.innerHTML = 'NO'; }
  else if (status == 'run') { el.style.background = '#3b82f6'; el.style.color = '#fff'; el.innerHTML = '...'; }
  else { el.style.background = '#334155'; el.style.color = '#64748b'; el.innerHTML = '-'; }
}

function checkNode() {
  try {
    var exec = shell.Exec("cmd /c node --version 2>&1");
    var output = "";
    while (!exec.StdOut.AtEndOfStream) output += exec.StdOut.ReadLine();
    if (output.indexOf("v") === 0) {
      nodeFound = true;
      document.getElementById('nodeMsg').innerHTML = 'Node.js ' + output + ' found!';
      document.getElementById('nodeMsg').style.color = '#4ade80';
      document.getElementById('nodeIcon').style.background = '#22c55e';
      document.getElementById('nodeIcon').style.color = '#fff';
      document.getElementById('nodeIcon').innerHTML = 'YES';
    }
  } catch(e) {}
}

function startInstall() { showStep(2); setTimeout(doInstall, 300); }

function doInstall() {
  setIcon('i1', 'run');
  log('Installing World Menu to ' + installDir + '...');

  // Check Node
  if (!nodeFound) {
    setIcon('i1', 'fail'); log('Node.js not found!');
    document.getElementById('errBox').style.display = '';
    document.getElementById('errBox').innerHTML = 'We need Node.js to run World Menu.<br>Download it free from <b>nodejs.org</b> then come back!';
    return;
  }

  // Copy files from source (USB/download) to C:\world-menu-pos
  var sourceDir = getSourceFiles();
  if (sourceDir !== installDir) {
    log('Copying files from ' + sourceDir + '...');
    shell.Run('cmd /c if not exist "' + installDir + '" mkdir "' + installDir + '"', 0, true);
    // Copy everything except node_modules and database
    shell.Run('cmd /c robocopy "' + sourceDir + '" "' + installDir + '" /E /XD node_modules .git /XF restaurant.db restaurant.db-shm restaurant.db-wal /NFL /NDL /NJH /NJS /NC /NS >nul 2>&1', 0, true);
    // If robocopy not available, fall back to xcopy
    if (!fso.FileExists(installDir + '\\package.json')) {
      shell.Run('cmd /c xcopy "' + sourceDir + '\\*" "' + installDir + '\\" /E /I /H /Y /Q >nul 2>&1', 0, true);
    }
    log('Files copied!');
  }

  setIcon('i1', 'ok'); log('Node.js ready, files in place!');

  setIcon('i2', 'run'); log('Installing dependencies (hang tight)...');
  try {
    shell.Run('cmd /c cd /d "' + installDir + '" && npm install >nul 2>&1', 0, true);
    setIcon('i2', 'ok'); log('Dependencies installed!');
  } catch(e) { setIcon('i2', 'fail'); log('Oops: ' + e.message); return; }

  setIcon('i3', 'run'); log('Building the app...');
  try {
    shell.Run('cmd /c cd /d "' + installDir + '\\client" && npx vite build >nul 2>&1', 0, true);
    shell.Run('cmd /c copy /y "' + installDir + '\\client\\public\\manifest.json" "' + installDir + '\\client\\dist\\" >nul 2>&1', 0, true);
    shell.Run('cmd /c copy /y "' + installDir + '\\client\\public\\embed.js" "' + installDir + '\\client\\dist\\" >nul 2>&1', 0, true);
    setIcon('i3', 'ok'); log('App built!');
  } catch(e) { setIcon('i3', 'fail'); log('Oops: ' + e.message); return; }

  setIcon('i4', 'run'); log('Creating shortcuts...');
  try {
    var desktop = shell.SpecialFolders("Desktop");
    var sc = shell.CreateShortcut(desktop + "\\World Menu POS.lnk");
    sc.TargetPath = installDir + "\\START.bat";
    sc.WorkingDirectory = installDir;
    sc.Description = "Launch World Menu POS";
    sc.IconLocation = installDir + "\\world-menu.ico,0";
    sc.Save();

    // Add/Remove Programs entry
    var rk = "HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\WorldMenuPOS\\";
    shell.RegWrite(rk + "DisplayName", "World Menu POS", "REG_SZ");
    shell.RegWrite(rk + "DisplayVersion", appVersion, "REG_SZ");
    shell.RegWrite(rk + "Publisher", "World Menu", "REG_SZ");
    shell.RegWrite(rk + "InstallLocation", installDir, "REG_SZ");
    shell.RegWrite(rk + "UninstallString", "cmd /c \"" + installDir + "\\uninstall.bat\"", "REG_SZ");
    shell.RegWrite(rk + "NoModify", 1, "REG_DWORD");
    shell.RegWrite(rk + "NoRepair", 1, "REG_DWORD");

    setIcon('i4', 'ok'); log('All set!');
  } catch(e) { setIcon('i4', 'ok'); log('Mostly done!'); }

  log(''); log('World Menu POS v' + appVersion + ' is ready!');
  setTimeout(function() { showStep(3); }, 600);
}

function launchApp() {
  var installDir = getInstallDir();
  shell.Run('cmd /c cd /d "' + installDir + '" && start START.bat', 1, false);
  setTimeout(function() { shell.Run('cmd /c start http://localhost:3000', 1, false); }, 4000);
}

function init() {
  resizeWindow();
  checkNode();
  appVersion = getVersion();
  document.getElementById('verLabel').innerHTML = 'v' + appVersion;
  showStep(0);
}
window.onload = init;
</script>
</head>
<body>
<div class="wrap">
  <div class="dots">
    <span class="dot" id="d0" style="background:#f59e0b"></span>
    <span class="dot" id="d1"></span>
    <span class="dot" id="d2"></span>
    <span class="dot" id="d3"></span>
  </div>

  <!-- WELCOME -->
  <div id="s0" class="step">
    <div class="big-emoji">&#127758;&#127869;</div>
    <h1>World Menu</h1>
    <div class="tagline">Your restaurant, every language, one system.</div>
    <div class="desc">The POS that speaks your customers' language.<br>Free. Fast. Beautiful.</div>
    <table class="ftable" cellspacing="6">
      <tr>
        <td><span class="ficon">&#127760;</span> 60+ Languages</td>
        <td><span class="ficon">&#128241;</span> Works on any tablet</td>
      </tr>
      <tr>
        <td><span class="ficon">&#128104;&#8205;&#127859;</span> Kitchen Display</td>
        <td><span class="ficon">&#128176;</span> POS + Payments</td>
      </tr>
      <tr>
        <td><span class="ficon">&#128424;</span> Auto Receipt Printing</td>
        <td><span class="ficon">&#128202;</span> Sales Reports</td>
      </tr>
      <tr>
        <td><span class="ficon">&#128197;</span> Reservations</td>
        <td><span class="ficon">&#127873;</span> Gift Cards + Loyalty</td>
      </tr>
    </table>
    <button class="btn btn-go btn-big" onclick="showStep(1)">Install World Menu POS</button>
    <div class="ver" id="verLabel">v1.0.0</div>
  </div>

  <!-- SYSTEM CHECK -->
  <div id="s1" class="step" style="display:none">
    <div class="big-emoji">&#128269;</div>
    <h2>Quick System Check</h2>
    <div class="desc">Making sure this computer is ready.</div>
    <div class="checks">
      <div class="chk">
        <span class="chk-icon" style="background:#22c55e;color:#fff">YES</span>
        Windows 10/11 &#10004;
      </div>
      <div class="chk">
        <span class="chk-icon" id="nodeIcon" style="background:#334155;color:#64748b">?</span>
        <span id="nodeMsg" style="color:#fbbf24">Node.js - looking...</span>
      </div>
    </div>
    <button class="btn btn-gray" onclick="showStep(0)">Back</button>
    <button class="btn btn-blue" onclick="startInstall()">Install!</button>
    <div class="small">Don't have Node.js? Grab it free at <b style="color:#60a5fa">nodejs.org</b></div>
  </div>

  <!-- INSTALLING -->
  <div id="s2" class="step" style="display:none">
    <div class="big-emoji">&#9889;</div>
    <h2>Setting up your restaurant...</h2>
    <div class="desc">Hang tight, this takes a minute or two.</div>
    <div class="checks">
      <div class="chk"><span class="chk-icon" id="i1" style="background:#334155;color:#64748b">-</span> Checking Node.js</div>
      <div class="chk"><span class="chk-icon" id="i2" style="background:#334155;color:#64748b">-</span> Installing ingredients</div>
      <div class="chk"><span class="chk-icon" id="i3" style="background:#334155;color:#64748b">-</span> Cooking the app</div>
      <div class="chk"><span class="chk-icon" id="i4" style="background:#334155;color:#64748b">-</span> Creating shortcuts</div>
    </div>
    <div class="log" id="logBox"></div>
    <div class="err-box" id="errBox"></div>
  </div>

  <!-- DONE! -->
  <div id="s3" class="step" style="display:none">
    <div class="big-emoji">&#127881;&#127881;&#127881;</div>
    <h2>You're ready to serve!</h2>
    <div class="tagline">World Menu POS is installed and ready to go.</div>
    <div class="desc">
      A shortcut has been added to your desktop.<br>
      Connect tablets to the same WiFi and open the URL shown when you launch.<br><br>
      Now go make some hungry people happy!
    </div>
    <button class="btn btn-green btn-big" onclick="launchApp()">&#127758; Launch World Menu!</button>
    <div class="small">Tip: Tap "Add to Home Screen" on tablets for app-like access!</div>
  </div>
</div>
</body>
</html>
